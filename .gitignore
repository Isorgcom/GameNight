# Credentials — never commit the real config
config/config.php

# SQLite database
db/

# Claude Code settings (may contain passwords/keys)
.claude/

# Docker / server deployment files (server-specific, not for publishing)
Dockerfile
docker-compose.yml
nginx.conf
server-prep.sh

# Runtime user-uploaded files (not source)
www/uploads/

# Backups
www/_backups/

# PHP vendor dependencies (composer-managed — uncomment if using composer)
# www/vendor/

# Third-party DB admin tools (download/deploy separately)
www/phpadmin/adminer.php
www/phpadmin/phpliteadmin.php
www/phpadmin/pla/
